# nova-ve backend environment — production deployment.
# The provisioning script (deploy/scripts/provision-ubuntu-2604.sh) generates
# this file at /etc/nova-ve/backend.env with random secrets.
#
# Settings marked "auto" are optional — they auto-generate on first run and
# persist to BASE_DATA_DIR.
APP_NAME=nova-ve
DEBUG=False
# SECRET_KEY — auto (generated to BASE_DATA_DIR/secret_key if unset)
# DATABASE_URL — auto (constructed from BASE_DATA_DIR/db_password if unset)
BASE_DATA_DIR=/var/lib/nova-ve
LABS_DIR=/var/lib/nova-ve/labs
IMAGES_DIR=/var/lib/nova-ve/images
USER_TEMPLATES_DIR=/var/lib/nova-ve/templates
TMP_DIR=/var/lib/nova-ve/tmp
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
# Admin user seeded by provision-ubuntu-2604.sh on first deploy.
# NOVA_VE_ADMIN_USERNAME=admin
# NOVA_VE_ADMIN_PASSWORD=<generated by provisioning script>
# NOVA_VE_ADMIN_EMAIL=admin@nova-ve.local
# NOVA_VE_ADMIN_NAME=Administrator
GUACAMOLE_PUBLIC_PATH=/html5/
GUACAMOLE_TARGET_HOST=host.docker.internal
GUACAMOLE_STATE_DIR=/var/lib/nova-ve/guacamole
# GUACAMOLE_DATABASE_URL=postgresql+asyncpg://guacuser:<password>@127.0.0.1:5433/guacdb
GUACAMOLE_DATA_SOURCE=postgresql
# GUACAMOLE_JSON_SECRET_KEY=<generated by provisioning script>
GUACAMOLE_JSON_EXPIRE_SECONDS=300
# GUACAMOLE_DB_PASSWORD=<generated by provisioning script>
GUACAMOLE_TERMINAL_FONT_NAME="Roboto Mono"
GUACAMOLE_TERMINAL_FONT_SIZE=10
