# Copy to .env and customize (all settings are optional — secrets auto-generate)
#
# SECRET_KEY — auto-generated on first run, persisted to $BASE_DATA_DIR/secret_key
# DATABASE_URL — auto-constructed from $BASE_DATA_DIR/db_password + DB_* vars below
#
# To set explicitly:
#   SECRET_KEY=<python -c "import secrets; print(secrets.token_hex(32))">
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
#
# DB_USER=nova
# DB_NAME=novadb
# DB_HOST=localhost
# DB_PORT=5432
REDIS_URL=redis://localhost:6379/0
